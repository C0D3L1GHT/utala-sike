-- lipu sike
kulupu_sike = {
}

kons = {}
telos = {}
selis = {}
kiwens = {}
-->8
-- ilo utala
-->8
-- lipu open
kule = {
 "kiwen",
 "kon",
 "seli",
 "telo"
 }
sinpin = {
 "ala","wan",
 "tu","tu_wan",
 "tu_tu","luka",
 "pipi","kala",
 "akesi","waso",
 "soweli","kije",
 "wawa","ante",
 "tawa","awen",
 "sin","pakala"
 }
kule_map = {9, 7, 8, 12}


-- cursor: 0=p1_s, 1=p1_k, 2=p2_s, 3=p2_k
ut_cursor = 0

p1 = {
 idx_k=1, 
 idx_s=1, 
 s_name="", 
 k_name="", 
 col=0,
 sprite=3, 
 ready=false
 }
p2 = {
 idx_k=1, 
 idx_s=1, 
 s_name="", 
 k_name="", 
 col=0,
 sprite=3,
 ready=false
 }

function init_utopen()
  update_player_data(p1)
  update_player_data(p2)
end

function update_utopen()
  update_player_data(p1)
  update_player_data(p2)

  if btnp(2) then 
   ut_cursor = 
      (ut_cursor - 1) % 4
   sfx(0)
  end
  if btnp(3) then 
   ut_cursor = 
      (ut_cursor + 1) % 4
   sfx(0) 
  end

  local active_p = 
      (ut_cursor < 2) and 
      p1 or p2
  local is_suit = 
      (ut_cursor % 2 == 1)

  if not active_p.ready then
    if is_suit then
      active_p.idx_k = 
      scroll_in_sel(
          active_p.idx_k, 
          kule, 
          0,
          1)
    else
      active_p.idx_s = 
      scroll_in_sel(
          active_p.idx_s,
          sinpin, 
          0, 
          1)
    end
  end

  if (btnp(5)) then
   if active_p.ready != true then
    active_p.ready = true
    add_sike(active_p)
    sfx(2)
   end
   
   if p1.ready == true and 
      p2.ready == true then
    sike_slct = false
    init_utala()
   end
   
  end
  if (btnp(4)) then 
   active_p.ready = false
   remove_sike(active_p)
  end
end

function update_player_data(p)
  p.s_name = sinpin[p.idx_s]
  p.k_name = kule[p.idx_k]
  p.col = kule_map[p.idx_k]
end

function add_sike(s)
 local new_ball = 
 {
  name = s.s_name.."_"..s.k_name,
  x  = 0,
  y  = 0,
  r  = 10,
  vx = 0,
  vy = 0,
  hp = 100,
  c  = s.col,
  sprite = s.sprite,
  status = "",
  timer = 20,
  list = {}
 }

 add(kulupu_sike,new_ball)
end

function remove_sike(s)
 if count(kulupu_sike)>0 then
  del(kulupu_sike,s)
 end
end

function scroll_in_sel(val, list, b_prev, b_next)
  if btnp(b_prev) then
   sfx(0)
   val -= 1
   if (val < 1) val = #list
  end
  if btnp(b_next) then
   sfx(0)
   val += 1
   if (val > #list) val = 1
  end
  return val
end

function draw_utopen()
  print("== sike open li seme ==", 24, 10, 7)
  
  -- draw p1 (cursor 0 and 1)
  draw_char_ui(p1, 30, 60, ut_cursor == 0 or ut_cursor == 1, ut_cursor % 2)
  
  -- draw p2 (cursor 2 and 3)
  draw_char_ui(p2, 90, 60, ut_cursor == 2 or ut_cursor == 3, ut_cursor % 2)
  
  if p1.ready and p2.ready then
    print("x - open utala!", 35, 110, 11)
  end
end

function draw_char_ui(p, x, y, is_active, row)
  local color_s = 
  	(is_active and row == 0) 
  	and 7 or 6
  local color_k = 
   (is_active and row == 1) 
   and 7 or 6
  
  if (is_active) print(">", x-6, y + (row * 10), 10)
  if (p.ready) print("ok", x-10, y+5, 11)
  
  print(p.s_name, x, y, color_s)
  print(p.k_name, x, y+10, color_k)
  
  circfill(x-18, y+7, 6, p.col)
  print(sub(p.s_name, 1, 1), x-20, y+5, 0)
end
