game_over = false
sike_slct = true
winner = "?"
hitstop = 0
grav = 0.025
clmp = 1.5

function _init()
 init_utopen()
end

function _update60()
 if sike_slct then
  update_utopen()
 else
  if game_over then return end
 
  check_gameover(kulupu_sike)
  update_utala()
 end
end

function _draw()
 cls(1)
 
 if sike_slct then
  draw_utopen()
 else

  draw_drops()
  draw_utala()
 
  if game_over then
   rectfill(20,60,120,80,0)
   print("ijo wawa li: " .. winner,32,64,7)
   return
  end
 end 
end
-->8
-- nasin utala

function init_utala()
 for s in all(kulupu_sike) do
  s.x = rnd(120)
  s.y = rnd(120)
  s.vx = rnd(1) - 2
  s.vy = rnd(1) - 2
 end
end

function update_utala()
 if hitstop > 0 then
  hitstop -= 1
  return 
 end
 
 for s in all(kulupu_sike) do
  query_death(s)
  update_wawa(s)
  wall_bounce(s)
  -- check_status(s) 
  -- if s speed is too low, bounce
  if abs(s.vx) < 0.025 and abs(s.vy) < 0.025 then
   s.vx = rnd(0.5)-1
   s.vy = rnd(0.5)-1
  end 
 end
 
 for i=1,#kulupu_sike-1 do
  for j=i+1,#kulupu_sike do
   check_collision(kulupu_sike[i], kulupu_sike[j])
  end
 end 
end

function wall_bounce(k)
 -- get unstuck in walls
 if k.x <= k.r then
  k.x = k.r
 elseif k.x >= 128 - k.r then
  k.x = 128 - k.r 
 end
 
 -- get unstuck in flr/ciel 
 if k.y <= k.r then
  k.y = k.r
 elseif k.y >= 128 - k.r then
  k.y = 128 - k.r
 end
 
 -- x-axis bounce
 if k.x + k.vx < k.r or k.x + k.vx > 128 - k.r then
  k.vx *= -(1 + (rnd(0.1) - 0.05))
  sfx(1)
  clamp_vel(k) 
 else
  k.x += k.vx
 end
 
 -- y-axis bounce
 if k.y + k.vy < k.r or k.y + k.vy > 128 - k.r then
  k.vy *= -(1 + (rnd(0.1) - 0.05))
  sfx(1)
  clamp_vel(k) 
 else
  k.y += k.vy
 end
 k.vy += grav
end

function check_collision(a,b)
 local dx = b.x - a.x
 local dy = b.y - a.y
 local dist = sqrt(dx*dx + dy*dy)
 if dist == 0 then dist = 0.1 end 
 local mindist = a.r + b.r
 
 if dist < mindist then
  determine_dmg(a,b)
  un_overlap(a,b)
  update_vel(a,b)
 
  sfx(0)
  hitstop = 10
  
 end 
end

function un_overlap(a,b)
 local dx = b.x - a.x
 local dy = b.y - a.y
 local dist = sqrt(dx*dx + dy*dy)
 local mindist = a.r + b.r
 
 local overlap = (mindist - dist)
 -- normals
 local nx = dx/dist
 local ny = dy/dist
 -- un-overlap balls
 a.x -= nx * (overlap/2)
 a.y -= ny * (overlap/2)
 b.x += nx * (overlap/2)
 b.y += ny * (overlap/2)
end

function update_vel(a,b)
 local dx = b.x - a.x
 local dy = b.y - a.y
 local dist = sqrt(dx*dx + dy*dy)

 -- normals
 local nx = dx/dist
 local ny = dy/dist

 -- update velocities
 local rvx = b.vx - a.vx
 local rvy = b.vy - a.vy
  
 local dot_prod = rvx*nx + rvy*ny
 -- balls are alreay moving away
 -- so return  
 if (dot_prod > 0) return
  
 -- bounce noise
 local b_noise = 1.5 + (rnd(0.2) - 0.1) 
 -- reflects the ball away (with noise)
 local reflect =
  -(1 + b_noise) * dot_prod
 reflect /= 2
 local refl_x = reflect * nx
 local refl_y = reflect * ny
 a.vx -= refl_x
 a.vy -= refl_y
 b.vx += refl_x
 b.vy += refl_y

 -- speed decay
 a.vx *= 0.98
 a.vy *= 0.98
 b.vx *= 0.98
 b.vy *= 0.98
 
 --clamp
 clamp_vel(a)
 clamp_vel(b)
end

function clamp_vel(i)
 i.vx = mid(-clmp, i.vx, clmp)
 i.vy = mid(-clmp, i.vy, clmp)
end

function determine_dmg(a,b)
 -- calculate damage
 local speed_a =
  sqrt(a.vx^2 + a.vy^2)
 local speed_b =
  sqrt(b.vx^2 + b.vy^2)
 
 if speed_a > speed_b then
  b.hp -=10  
  -- increase loser speed
  b.vx *= 1.5
  b.vy *= 1.5
  -- decrease winner speed
  a.vx *= 0.90
  a.vy *= 0.90
 elseif speed_b > speed_a then
  a.hp -=10  
  -- increase loser speed
  a.vx *= 1.5
  a.vy *= 1.5
  -- decrease winner speed
  b.vx *= 0.90
  b.vy *= 0.90
 end
end

function query_death(s)
 if s.hp <= 0 then
  sfx(6)
  del(kulupu_sike,s)
 end
end

function check_gameover(k)
 if count(k)==1 then
   sfx(4)
   winner = k[1].name 
   game_over = true
 end
end

function draw_utala()
 for s in all(kulupu_sike) do
  circfill(s.x, s.y, s.r, s.c)
  spr(s.sprite, s.x-4, s.y-4)
  print(s.name .. ": " .. s.hp .. " ", s.c-1)
  -- debugs
  --print(s.name .. ": " .. s.hp .. " " .. s.status, s.c-1)
  --print(s.vx .. " " .. s.vy, s.c-1)
 end
end
-->8
-- lipu wawa
function update_wawa(s)
 -- collision logic
 for item in all(s.list) do
  local dx=item.x-s.x
  local dy=item.y-s.y
  -- delete tile when collide
  if(dx*dx+dy*dy)<
  (s.r+item.r)^2 then
   sfx(2)
   del(s.list,item)
   apply_effect(s,s.c)
  end
 end

 -- spawning logic
 s.timer-=1
 if s.timer<=0 then
  local v2=s.vx*s.vx+s.vy*s.vy
  local speed=sqrt(v2)
      
  if speed>0.1 then
   add(s.list,{
   x=mid(0,s.x-(s.vx/speed*s.r*1.5),128),
   y=mid(0,s.y-(s.vy/speed*s.r*1.5),128),
   r=1,
   sprite=s.c
   })
  end
  s.timer=100+rnd(10)
 end
end

function apply_effect(s,c)
 if c==7 then      -- kon
  s.vx*=5 s.vy*=5
 elseif c==12 then -- telo
  s.vx*=-3 s.vy*=-3
 elseif c==8 then  -- seli
  s.vx=rnd(0.4)-0.8 s.vy=-5
 elseif c==9 then  -- kiwen
  s.vx=rnd(0.4)-0.8 s.vy=5
 end
 --s.vx=mid(-clmp,s.vx,clmp)
 --s.vy=mid(-clmp,s.vy,clmp)
end

function draw_drops()
 -- draw all tiles
 for s in all(kulupu_sike) do
  -- determine tile
  local sprs=0
  if s.c == 7 then
   sprs=224
  elseif s.c == 12 then
   sprs=225
  elseif s.c == 8 then
   sprs=226
  elseif s.c == 9 then
   sprs=227
  end
 	for item in all(s.list) do
  	 spr(sprs
   	,item.x,item.y)
 	end
 end
end
